"]}}}"
)
}
# project fields to be remapped
criteria <- paste0(
criteria,
", {'$addFields':{",
"'GLOBAL_UNIQUE_IDENTIFIER': '$OBSERVATIONS.GLOBAL_UNIQUE_IDENTIFIER',",
"'CATEGORY': '$OBSERVATIONS.CATEGORY',",
"'COMMON_NAME': '$OBSERVATIONS.COMMON_NAME',",
"'SCIENTIFIC_NAME': '$OBSERVATIONS.SCIENTIFIC_NAME',",
"'BREEDING_CATEGORY': '$OBSERVATIONS.BREEDING_CATEGORY',",
"'BREEDING_CODE': '$OBSERVATIONS.BREEDING_CODE',",
"'BEHAVIOR_CODE': '$OBSERVATIONS.BEHAVIOR_CODE',",
"'OBSERVATIONS.GLOBAL_UNIQUE_IDENTIFIER':0,",
"'OBSERVATIONS.COMMON_NAME':0,",
"'OBSERVATIONS.SCIENTIFIC_NAME':0,",
"'OBSERVATIONS.BREEDING_CATEGORY':0,",
"'OBSERVATIONS.CATEGORY':0,",
"'OBSERVATIONS.BEHAVIOR_CODE':0}}"
)
}
# close criteria query
criteria <- paste0(criteria, "]")
}
